{
  "schema_version": "1.0",
  "name": "JadeGate",
  "description": "Transparent security proxy for MCP servers. 6-layer protection stack: policy enforcement, runtime monitoring, transport proxy, trust verification, security scanning, auto-installation. Zero config — pip install jadegate.",
  "url": "https://jadegate.io",
  "capabilities": [
    "mcp_proxy",
    "policy_enforcement",
    "runtime_monitoring",
    "trust_verification",
    "security_scanning",
    "auto_installation"
  ],
  "integration": {
    "install": "pip install jadegate",
    "commands": {
      "status": "jadegate status",
      "scan": "jadegate scan",
      "install": "jadegate install",
      "uninstall": "jadegate uninstall"
    },
    "python_sdk": {
      "env_var": "JADEGATE=1",
      "programmatic": "import jadegate; jadegate.activate()"
    }
  },
  "supported_clients": [
    "Claude Desktop",
    "Cursor",
    "Windsurf",
    "Cline",
    "Continue",
    "Zed"
  ],
  "security_model": {
    "type": "deterministic",
    "layers": 6,
    "crypto": "Ed25519",
    "trust_model": "TOFU",
    "offline": true,
    "telemetry": false,
    "fail_mode": "open"
  },
  "contact": {
    "github": "https://github.com/JadeGate",
    "issues": "https://github.com/JadeGate/jade-core/issues"
  }
}
